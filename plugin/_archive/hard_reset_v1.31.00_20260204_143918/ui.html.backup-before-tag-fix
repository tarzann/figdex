      function extractFileNameFromUrl(url) {
        // Extract file name from URL: https://www.figma.com/file/ABC123/Project-Name?node-id=...
        // The file name is between the file key and the ? or end of URL
        try {
          // Try multiple patterns to handle different URL formats
          let match = url.match(/figma\.com\/(?:file|design)\/[a-zA-Z0-9]+\/([^?\/]+)/);
          if (!match) {
            // Try alternative pattern
            match = url.match(/figma\.com\/(?:file|design)\/[a-zA-Z0-9]+\/([^\/\?]+)/);
          }
          if (match && match[1]) {
            // Decode URL encoding (handles %20 for spaces, etc.)
            let fileName = decodeURIComponent(match[1]).trim();
            // Replace dashes with spaces for better readability
            fileName = fileName.replace(/-/g, ' ');
            console.log('✅ Extracted fileName from URL:', fileName);
            return fileName;
          }
          console.warn('⚠️ Could not extract fileName from URL:', url);
          return '';
        } catch (e) {
          console.error('❌ Error extracting fileName from URL:', e);
          return '';
