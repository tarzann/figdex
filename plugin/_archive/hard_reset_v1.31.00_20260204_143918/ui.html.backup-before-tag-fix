          if (!fileData.fileKey || fileData.fileKey === 'unknown' || (typeof fileData.fileKey === 'string' && fileData.fileKey.trim() === '')) {
            const errorMsg = '❌ File Key Required\n\nPlease set the Figma file key before uploading:\n\n1. Click "Set File Key" button\n2. Paste your Figma file URL (e.g., https://www.figma.com/file/abc123xyz456/Project-Name)\n3. Or enter the file key directly\n\nThe file key is required to link frames to your Figma file.';
            console.error('❌ Validation failed:', errorMsg);
            updateUploadProgress('File Key Required', 0, errorMsg, 'Error', 'Failed', 0, 0);
            throw new Error(errorMsg);
          }

          // Validate fileName - if missing or 'Untitled', try to get from indexData
          // Don't use fileKey as fallback here - let the API handle it
          if (!fileData.fileName || typeof fileData.fileName !== 'string' || fileData.fileName.trim() === '' || fileData.fileName === 'Untitled') {
            // Try to get from indexData
            const fileNameFromIndex = (indexData.fileName) || 
                                    (indexData.data && indexData.data.fileName) || 
                                    null;
            if (fileNameFromIndex && fileNameFromIndex.trim() && fileNameFromIndex !== 'Untitled') {
              fileData.fileName = fileNameFromIndex;
            } else {
              // Keep 'Untitled' - the API will handle it and use fileKey as fallback
              fileData.fileName = 'Untitled';
              console.warn('⚠️ fileName is Untitled - API will use fileKey as fallback');
            }
          }

          if (!pagesToUpload || pagesToUpload.length === 0) {
            const errorMsg = '❌ No Pages to Upload\n\nNo frames were found to upload. Please ensure you have selected frames to index.';
            console.error('❌ Validation failed:', errorMsg);
            updateUploadProgress('No Pages to Upload', 0, errorMsg, 'Error', 'Failed', 0, 0);
            throw new Error(errorMsg);
          }
          
          console.log('✅ Validation passed');
          
          // Helper: convert base64 data URL to Blob
          function dataUrlToBlob(dataUrl) {
            try {
              const parts = dataUrl.split(',');
              const meta = parts[0]; // data:image/png;base64
              const base64 = parts[1] || '';
              const mimeMatch = /^data:(.*?);base64$/.exec(meta);
              const mime = mimeMatch ? mimeMatch[1] : 'application/octet-stream';
              const binary = atob(base64);
              const len = binary.length;
              const bytes = new Uint8Array(len);
              for (let i = 0; i < len; i++) bytes[i] = binary.charCodeAt(i);
              return { blob: new Blob([bytes], { type: mime }), mime };
            } catch (e) {
              console.error('dataUrlToBlob failed', e);
              return { blob: null, mime: 'application/octet-stream' };
            }
          }
          
          // Upload images directly to Supabase Storage, then send manifest to upload-index-v2
          async function uploadViaStorageAndManifest(pages) {
            // Count frames with images
            const allFrames = [];
            pages.forEach(p => Array.isArray(p.frames) && p.frames.forEach(f => allFrames.push(f)));
            const framesWithImage = allFrames.filter(f => f && typeof f.image === 'string' && f.image.startsWith('data:'));
            
            let completed = 0;
            const total = framesWithImage.length;
            const startSizeBytes = JSON.stringify(pages).length;
            const initialSizeMB = +(startSizeBytes / 1024 / 1024).toFixed(2);
            
            // Concurrency limit
            const limit = 3;
            let idx = 0;
            async function worker() {
              while (idx < framesWithImage.length) {
                const curIndex = idx++;
                const frame = framesWithImage[curIndex];
                try {
                  const { blob, mime } = dataUrlToBlob(frame.image);
                  if (!blob) { completed++; continue; }
                  const ext = mime.includes('png') ? 'png' : (mime.includes('jpeg') || mime.includes('jpg') ? 'jpg' : 'bin');
                  const safeName = (frame.name || 'frame').replace(/[^a-zA-Z0-9_\-]+/g, '_').slice(0, 40);
                  const fileName = `${fileData.fileKey}_${frame.id}_${safeName}.${ext}`;
                  
                  // 1) get signed upload URL
                  const signed = await fetch('https://www.figdex.com/api/storage/signed-upload', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                    body: JSON.stringify({ filename: fileName, contentType: mime, projectId: fileData.documentId })
                  });
                  if (!signed.ok) {
                    const t = await signed.text();
                    throw new Error(`signed-upload failed (${signed.status}): ${t}`);
                  }
                  const sig = await signed.json();
                  
                  // 2) upload the blob to signedUrl
                  // Supabase requires Authorization header and PUT for signed uploads
                  const uploadHeaders = { 'Content-Type': mime, 'x-upsert': 'true' };
                  if (sig && sig.anonKey) {
                    uploadHeaders['Authorization'] = `Bearer ${sig.anonKey}`;
                  }
                  const up = await fetch(sig.signedUrl, {
                    method: 'PUT',
                    headers: uploadHeaders,
                    body: blob
                  });
                  if (!up.ok) {
                    const t = await up.text();
                    throw new Error(`storage upload failed (${up.status}): ${t}`);
                  }
                  
                  // 3) save publicUrl on frame, remove inline image
                  frame.image_url = sig.publicUrl || null;
                  delete frame.image;
                } catch (e) {
                  console.error('Storage upload error for frame', frame?.id, e);
                } finally {
                  completed++;
                  const pct = total ? Math.round((completed / total) * 60) : 60;
                  const elapsed = uploadStartTime ? (Date.now() - uploadStartTime) / 1000 : 0;
                  updateUploadProgress(`Uploading images (${completed}/${total})...`, 30 + pct, `Saving to storage`, fileData.fileName, `Images`, initialSizeMB, elapsed);
                }
              }
            }
            const workers = Array.from({ length: Math.min(limit, Math.max(1, total)) }, () => worker());
            await Promise.all(workers);
            
            // 4) Post manifest (without base64 images)
            updateUploadProgress('Saving manifest...', 95, 'Finalizing index data', fileData.fileName, 'Manifest', initialSizeMB, (Date.now() - uploadStartTime) / 1000);
            const resp = await fetch('https://www.figdex.com/api/upload-index-v2', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
              body: JSON.stringify({
                documentId: fileData.documentId,
                fileKey: fileData.fileKey,
                fileName: fileData.fileName,
                pages
              })
            });
            if (!resp.ok) {
              const t = await resp.text();
              throw new Error(`upload-index-v2 failed (${resp.status}): ${t}`);
            }
            const j = await resp.json();
            const totalTime = stopUploadTimer();
            updateUploadProgress('Upload Complete!', 100, `Frames: ${allFrames.length}`, fileData.fileName, 'Successfully uploaded', initialSizeMB, totalTime);
            setTimeout(() => { const overlay = document.getElementById('uploadOverlay'); if (overlay) overlay.remove(); }, 2000);
            return j;
          }
          
          // Prefer Storage + Manifest path for robust large uploads; on failure, fall back
          try {
            await uploadViaStorageAndManifest(pagesToUpload);
            return; // success, stop here
          } catch (e) {
            console.warn('Storage/manifest path failed, falling back to server upload:', e);
            // continue to V2/legacy fallbacks below
          }
          
          // Try Upload V2 (session → append → commit). If it returns true, we're done; if false, fall back to legacy
          async function tryUploadV2(fileData, pagesToUpload, token, initialSizeMB) {
            try {
              updateUploadProgress('Starting session...', 25, 'Initializing upload session (V2)', fileData.fileName, 'Session', initialSizeMB, 0);
              const sessResp = await fetch('https://www.figdex.com/api/uploads', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ fileKey: fileData.fileKey, fileName: fileData.fileName, documentId: fileData.documentId })
              });
              if (!sessResp.ok) {
                const txt = await sessResp.text();
                throw new Error(`Create session failed (${sessResp.status}): ${txt}`);
              }
              const sess = await sessResp.json();
              const uploadId = sess.uploadId;
              const appendUrl = new URL(sess.appendUrl, 'https://www.figdex.com').toString();
              const commitUrl = new URL(sess.commitUrl, 'https://www.figdex.com').toString();
              const maxChunkMB = (sess.limits && sess.limits.maxChunkMB) ? sess.limits.maxChunkMB : 2;
              const maxBytes = maxChunkMB * 1024 * 1024;

              // Split by size
              const queue = [...pagesToUpload];
              const rawChunks = [];
              let cur = [];
              let curBytes = 0;
              while (queue.length) {
                const page = queue.shift();
                const b = JSON.stringify(page).length;
                if (curBytes + b > maxBytes && cur.length > 0) {
                  rawChunks.push(cur);
                  cur = [page];
                  curBytes = b;
                } else {
                  cur.push(page);
                  curBytes += b;
                }
              }
              if (cur.length) rawChunks.push(cur);

              // Adjust oversized single-page chunks by splitting frames
              const adjusted = [];
              while (rawChunks.length) {
                const c = rawChunks.shift();
                const probe = JSON.stringify({ pages: c }).length;
                if (probe > maxBytes && c.length === 1 && Array.isArray(c[0].frames) && c[0].frames.length > 1) {
                  const frames = c[0].frames;
                  const mid = Math.ceil(frames.length / 2);
                  const A = { ...c[0], frames: frames.slice(0, mid) };
                  const B = { ...c[0], frames: frames.slice(mid) };
                  rawChunks.unshift([A]);
                  rawChunks.unshift([B]);
                } else if (probe > maxBytes && c.length > 1) {
                  const mid = Math.floor(c.length / 2);
                  rawChunks.unshift(c.slice(0, mid));
                  rawChunks.unshift(c.slice(mid));
                } else {
                  adjusted.push(c);
                }
              }

              console.log(`V2: uploading ${adjusted.length} chunks (max ${maxChunkMB}MB each)`);
              let totalFrames = 0;
              let uploadedMB = 0;
              for (let i = 0; i < adjusted.length; i++) {
                const chunk = adjusted[i];
                const chunkBytes = JSON.stringify(chunk).length;
                const chunkMB = +(chunkBytes / 1024 / 1024).toFixed(2);
                const elapsed = uploadStartTime ? (Date.now() - uploadStartTime) / 1000 : 0;
                updateUploadProgress(`Uploading chunk ${i + 1}/${adjusted.length}...`, 30 + Math.round((i / adjusted.length) * 50), `Chunk ~${chunkMB}MB`, fileData.fileName, `Chunk ${i + 1}`, initialSizeMB, elapsed);

                const ar = await fetch(appendUrl, {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                  body: JSON.stringify({ pages: chunk, fileKey: fileData.fileKey, fileName: fileData.fileName, uploadedAt: new Date().toISOString() })
                });
                if (!ar.ok) {
                  const t = await ar.text();
                  throw new Error(`Append failed (${ar.status}): ${t}`);
                }
                const aj = await ar.json();
                totalFrames += aj.frames || 0;
                uploadedMB += aj.size || 0;
              }

              const cr = await fetch(commitUrl, { method: 'POST', headers: { 'Authorization': `Bearer ${token}` } });
              if (!cr.ok) {
                const t = await cr.text();
                throw new Error(`Commit failed (${cr.status}): ${t}`);
              }
              const cj = await cr.json();

              const totalTime = stopUploadTimer();
              const finalFrames = cj.frames ?? totalFrames;
              const finalSizeMB = cj.size ?? initialSizeMB;
              updateUploadProgress('Upload Complete!', 100, `Chunks: ${adjusted.length} | Frames: ${finalFrames} | Size: ${finalSizeMB}MB`, fileData.fileName, 'Successfully uploaded', finalSizeMB, totalTime);
              setTimeout(() => { const overlay = document.getElementById('uploadOverlay'); if (overlay) overlay.remove(); }, 3000);
              return true;
            } catch (e) {
              const msg = (e && e.message) ? e.message : String(e);
              console.log('V2 upload failed:', msg);
              // Allow fallback only if session creation/append endpoints are truly unavailable
              if (/Create session failed\s*\(40[45]|501\)/i.test(msg) || /Append failed\s*\(40[45]|501\)/i.test(msg)) {
                console.log('V2 endpoints unavailable – falling back to legacy');
                return false;
              }
              // For commit/server errors (e.g., 500/schema), avoid duplicate legacy upload
              // and surface the error to the user instead
              throw new Error(msg);
            }
          }

          // Build payload
          const payload = {
            documentId: fileData.documentId,
            fileKey: fileData.fileKey,
            fileName: fileData.fileName,
            pages: pagesToUpload,
            uploadedAt: new Date().toISOString(),
            tags: uniqueTags,
            tagStatistics: tagStats
          };
          
          // Calculate file size from pages only (not the entire payload)
          const pagesSizeBytes = JSON.stringify(pagesToUpload).length;
          const sizeInMB = parseFloat((pagesSizeBytes / 1024 / 1024).toFixed(2));
          const fileSizeBytes = pagesSizeBytes; // Size in bytes (pages only)
          console.log(`File size (pages only): ${sizeInMB}MB (${fileSizeBytes} bytes)`);
          
          // Add file_size to payload (in bytes) - size of pages only
          payload.file_size = fileSizeBytes;
          
          // Start timer if not already started
          if (!uploadStartTime) {
            startUploadTimer();
          }
          
          // Vercel limit is ~4.5MB - add headroom
          const VERCEL_LIMIT_MB = 3.5;
          const needsChunking = sizeInMB > VERCEL_LIMIT_MB;
          const isLargeFile = sizeInMB > 10;
          
          // Update progress with size info
          let statusMessage = 'Preparing upload...';
          let detailsMessage = `File: ${fileData.fileName} | Size: ${sizeInMB}MB`;
          
          if (isLargeFile) {
            statusMessage = 'Preparing large file... This may take a moment';
            detailsMessage = `Large file detected (${sizeInMB}MB) - Processing frames and images...`;
            updateUploadProgress(
              statusMessage,
              15,
              detailsMessage,
              fileData.fileName,
              'Processing large file...',
              sizeInMB,
              0
            );
          } else {
            updateUploadProgress(
              statusMessage,
              20,
              detailsMessage,
              fileData.fileName,
              'Ready to upload',
              sizeInMB,
              0
            );
          }

          // Optionally attempt server-side V2 (disabled by default to avoid large commit limits)
          const ENABLE_SERVER_V2 = false;
          if (ENABLE_SERVER_V2) {
            const v2Done = await tryUploadV2(fileData, pagesToUpload, token, sizeInMB);
            if (v2Done) return;
          }
          
          if (needsChunking) {
            console.log('File too large, splitting into chunks...');
            const chunkStatusMsg = `Large file (${sizeInMB}MB) - Splitting into chunks for upload...`;
            updateUploadProgress(
              chunkStatusMsg,
              30,
              `File size: ${sizeInMB}MB exceeds limit - splitting into smaller parts`,
              fileData.fileName,
              'Chunking',
              sizeInMB,
              0
            );
            await uploadInChunksBySize(indexData, token, fileData, userEmail, userName, userProvider, userProviderId, VERCEL_LIMIT_MB, sizeInMB);
            return;
          }
          
          // Update progress before upload
          const elapsed = uploadStartTime ? (Date.now() - uploadStartTime) / 1000 : 0;
          updateUploadProgress(
            'Uploading to server...', 
            50, 
            `Sending ${sizeInMB}MB to FigDex Web`, 
            fileData.fileName,
            'Uploading',
            sizeInMB,
            elapsed
          );
          
          // Use fetch API from UI
          const response = await fetch('https://www.figdex.com/api/upload-index', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(payload)
          });
          
          if (!response.ok) {
            const errorText = await response.text();
            throw new Error(`HTTP ${response.status}: ${errorText}`);
          }
          
          const result = await response.json();
          
          // Stop timer and get final elapsed time
          const totalTime = stopUploadTimer();
          
          // Use size from response if available, otherwise use calculated size
          const finalSizeMB = result.size || sizeInMB;
          const framesCount = result.frames || 0;
          
          // Update progress to show success
          updateUploadProgress(
            'Upload Complete!', 
            100, 
            `Chunks: 1 | Frames: ${framesCount} | Size: ${finalSizeMB.toFixed(2)}MB`, 
            fileData.fileName,
            'Successfully uploaded',
            finalSizeMB,
            totalTime
          );
          
          // Close the upload overlay after 3 seconds
          setTimeout(() => {
            const overlay = document.getElementById('uploadOverlay');
            if (overlay) {
              overlay.remove();
            }
          }, 3000);
          
          return result;
            
        } catch (error) {
          console.error('💥 Upload error:', error);
          const errorMsg = error.message || 'Unknown error occurred';
          
          // Show error in overlay
          updateUploadProgress('Upload Failed', 0, errorMsg, 'Error', 'Failed', 0, 0);
          
          // Show alert
          alert(`Upload failed: ${errorMsg}`);
          
          // Close the upload overlay after 5 seconds
          setTimeout(() => {
            const overlay = document.getElementById('uploadOverlay');
            if (overlay) {
              overlay.remove();
            }
          }, 5000);
        }
      }
      
      // New function: split by size instead of page count
      async function uploadInChunksBySize(indexData, token, fileData, userEmail, userName, userProvider, userProviderId, maxSizeMB, totalFileSizeMB) {
        try {
          const allPages = indexData.data.pages || [];
          const maxSizeBytes = maxSizeMB * 1024 * 1024;
          const chunks = [];
          let currentChunk = [];
          let currentSize = 0;
          
          // Split pages into chunks based on size
          for (const page of allPages) {
            const pageSize = JSON.stringify(page).length;
            
            // If adding this page would exceed limit, save current chunk and start new one
            if (currentSize + pageSize > maxSizeBytes && currentChunk.length > 0) {
              chunks.push(currentChunk);
              currentChunk = [page];
              currentSize = pageSize;
            } else {
              currentChunk.push(page);
              currentSize += pageSize;
            }
          }
          
          // Don't forget the last chunk
          if (currentChunk.length > 0) {
            chunks.push(currentChunk);
          }
          
          // Calculate total file size in bytes from all pages
          const totalFileSizeBytes = JSON.stringify(allPages).length;
          const calculatedTotalSizeMB = parseFloat((totalFileSizeBytes / 1024 / 1024).toFixed(2));
          console.log(`Uploading ${allPages.length} pages in ${chunks.length} chunks (max ${maxSizeMB}MB each), total size: ${calculatedTotalSizeMB}MB (${totalFileSizeBytes} bytes)`);

          // Ensure each chunk payload fits under limit; if not, split further
          const maxBytes = maxSizeMB * 1024 * 1024;
          const queue = [...chunks];
          const adjustedChunks = [];
          while (queue.length > 0) {
            const chunkPages = queue.shift();
            // Estimate payload size with minimal wrapper (using validated data)
            const probePayload = {
              documentId: `${fileData.documentId}-probe`,
              fileKey: fileData.fileKey,
              fileName: `${fileData.fileName} (Probe)`,
              pages: chunkPages
            };
            const estimatedBytes = JSON.stringify(probePayload).length;
            if (estimatedBytes > maxBytes) {
              if (chunkPages.length > 1) {
                // Split by pages (halves)
                const mid = Math.floor(chunkPages.length / 2);
                queue.push(chunkPages.slice(0, mid));
                queue.push(chunkPages.slice(mid));
              } else if (chunkPages.length === 1) {
                // Split inside page by frames
                const page = chunkPages[0];
                const frames = Array.isArray(page.frames) ? page.frames : [];
                if (frames.length > 1) {
                  const mid = Math.ceil(frames.length / 2);
                  const pageA = { ...page, frames: frames.slice(0, mid) };
                  const pageB = { ...page, frames: frames.slice(mid) };
                  queue.push([pageA]);
                  queue.push([pageB]);
                } else {
                  // As a last resort, push as-is to avoid infinite loop
                  adjustedChunks.push(chunkPages);
                }
              } else {
                adjustedChunks.push(chunkPages);
              }
            } else {
              adjustedChunks.push(chunkPages);
            }
          }
          console.log(`Adjusted chunks count: ${adjustedChunks.length}`);
          
          // Update progress for chunked upload
          const elapsed = uploadStartTime ? (Date.now() - uploadStartTime) / 1000 : 0;
          updateUploadProgress(
            `Uploading large file in ${adjustedChunks.length} chunks...`, 
            40, 
            `Total size: ${calculatedTotalSizeMB}MB - Preparing ${adjustedChunks.length} chunks for upload`, 
            fileData.fileName || 'Untitled',
            'Chunked upload',
            calculatedTotalSizeMB,
            elapsed
          );
          
          let totalFrames = 0;
          let totalSize = 0;
          
          // Upload each chunk
          for (let i = 0; i < adjustedChunks.length; i++) {
            // Update progress for current chunk
            const progress = 40 + (i / adjustedChunks.length) * 50; // 40% to 90%
            const elapsed = uploadStartTime ? (Date.now() - uploadStartTime) / 1000 : 0;
            updateUploadProgress(
              `Uploading chunk ${i + 1}/${adjustedChunks.length}...`, 
              Math.round(progress), 
              `Chunk ${i + 1} of ${adjustedChunks.length} (${calculatedTotalSizeMB}MB total)`, 
              fileData.fileName || 'Untitled',
              `Processing chunk ${i + 1}`,
              calculatedTotalSizeMB,
              elapsed
            );
            const chunk = adjustedChunks[i];
            // Get tag statistics for each chunk
            const tagStats = getTagStatistics();
            const uniqueTags = getAllUniqueTags();
            
            const chunkPayload = {
              documentId: `${fileData.documentId}-chunk${i + 1}`,
              fileKey: fileData.fileKey,
              fileName: `${fileData.fileName} (Part ${i + 1}/${adjustedChunks.length})`,
              pages: chunk,
              uploadedAt: new Date().toISOString(),
              tags: uniqueTags, // Send unique tags
              tagStatistics: tagStats // Add tag usage statistics
            };
            
            // Calculate chunk size from pages only (not the entire payload)
            const chunkPagesSizeBytes = JSON.stringify(chunk).length;
            const chunkSizeInMB = (chunkPagesSizeBytes / 1024 / 1024).toFixed(2);
            console.log(`Chunk ${i + 1}/${adjustedChunks.length} size: ${chunkSizeInMB}MB (${chunkPagesSizeBytes} bytes, ${chunk.length} pages), total file size: ${calculatedTotalSizeMB}MB (${totalFileSizeBytes} bytes)`);
            
            // Add file_size to chunk payload (in bytes) - use total size for all chunks
            // When chunks are merged, the total size will be correct (sum of all chunks = totalFileSizeBytes)
            chunkPayload.file_size = totalFileSizeBytes;
            
            const response = await fetch('https://www.figdex.com/api/upload-index', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
                  },
              body: JSON.stringify(chunkPayload)
                });
                
                if (response.ok) {
              const result = await response.json();
              console.log(`Chunk ${i + 1} response:`, JSON.stringify(result, null, 2));
              const framesCount = result.frames || 0;
              const sizeMB = parseFloat(result.size) || 0;
              totalFrames += framesCount;
              totalSize += sizeMB;
              console.log(`Chunk ${i + 1} uploaded successfully: ${framesCount} frames, ${sizeMB}MB`);
                } else {
              const errorText = await response.text();
              console.log(`Chunk ${i + 1} failed: HTTP ${response.status}: ${errorText}`);
              // Continue with next chunk instead of failing completely
              continue;
            }
          }
          
          // Stop timer and get final elapsed time
          const totalTime = stopUploadTimer();
          
          // Update progress to show success
