            }
          }, '*');
        
          // Wait for file data response with timeout
          fileData = await new Promise((resolve, reject) => {
            let timeoutId;
            let resolved = false;
            
            const cleanup = () => {
              window.removeEventListener('message', handleFileData);
              if (timeoutId) clearTimeout(timeoutId);
            };
            
            const handleFileData = (event) => {
              console.log('📨 Message received:', event.data);
              
              if (resolved) {
                console.log('⚠️ Already resolved, ignoring message');
                return;
              }
              
              // Check if this is a plugin message
              if (!event.data || !event.data.pluginMessage) {
                console.log('ℹ️ Not a plugin message, ignoring');
                return;
              }
              
              const msgType = event.data.pluginMessage.type;
              console.log('📋 Message type:', msgType);
              
              if (msgType === 'file-data-error') {
                resolved = true;
                cleanup();
                const errorMsg = `❌ Failed to get file data from plugin: ${event.data.pluginMessage.error || 'Unknown error'}`;
                console.error('❌', errorMsg);
                reject(new Error(errorMsg));
                return;
