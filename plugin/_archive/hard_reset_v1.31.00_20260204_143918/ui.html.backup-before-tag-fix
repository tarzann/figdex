          }
        }
        
        if (msg && msg.type === 'FigDex-page-status') {
          console.log('Received FigDex page status:', msg);
          const { exists, hasFrames, frameCount, error } = msg;
          updateUploadButtonStatus(exists, hasFrames, frameCount || 0);
          
          if (error) {
            console.log('FigDex page issue:', error);
          }
        }
        
        if (msg && msg.type === 'index-data-ready') {
          // Index data is ready from plugin - prepare for upload
          if (window.uploadOverlay) {
            updateUploadProgress(
              'Index ready, preparing upload...',
              10,
              'Processing index data and calculating size...',
              'Loading...',
              'Index built',
              undefined,
              uploadStartTime ? (Date.now() - uploadStartTime) / 1000 : 0
            );
          }
          // The upload will continue in uploadToWebSystemFromUI when file data is ready
        }
        
        if (msg && msg.type === 'index-data-error') {
          // Error building index
          if (window.uploadOverlay) {
            const totalTime = stopUploadTimer();
            updateUploadProgress(
              'Index Build Failed',
              0,
              `Error: ${msg.error || 'Unknown error'}`,
              'Error',
              'Failed to build index',
              undefined,
              totalTime
            );
            setTimeout(() => {
              const overlay = document.getElementById('uploadOverlay');
              if (overlay) {
                overlay.remove();
              }
            }, 3000);
          }
        }
        
        if (msg && msg.type === 'upload-data-ready') {
          // Handle the upload in UI
          uploadToWebSystemFromUI(msg.indexData, msg.token, msg.userEmail, msg.userName, msg.userProvider, msg.userProviderId);
        }
        
        if (msg && msg.type === 'SUPABASE_TOKENS_LOADED') {
          // Store Supabase tokens for use in upload functions
          window.supabaseAccessToken = msg.accessToken;
          window.supabaseRefreshToken = msg.refreshToken;
        }
        
        if (msg && msg.type === 'done') {
          isIndexing = false;
          hideProgressDrawer();
          const loading = document.getElementById('loading');
          const doneMsg = document.getElementById('doneMsg');
          const errorMsg = document.getElementById('errorMsg');
          const advanceBtn = document.getElementById('advanceBtn');
          if (loading) loading.style.display = 'none';
          if (doneMsg) doneMsg.style.display = 'block';
          if (errorMsg) errorMsg.style.display = 'none';
          if (advanceBtn) advanceBtn.disabled = false;
          renderPagesList();
          updateCurrentFileKeyLabel();
        }
        if (msg && msg.type === 'error') {
          isIndexing = false;
          hideProgressDrawer();
          const loading = document.getElementById('loading');
          const doneMsg = document.getElementById('doneMsg');
          const errorMsg = document.getElementById('errorMsg');
          const advanceBtn = document.getElementById('advanceBtn');
          if (loading) loading.style.display = 'none';
          if (doneMsg) doneMsg.style.display = 'none';
          if (errorMsg) errorMsg.style.display = 'block';
          if (advanceBtn) advanceBtn.disabled = false;
          renderPagesList();
          updateCurrentFileKeyLabel();
        }
        if (msg && msg.type === 'progress') {
          if (!progressByPage[msg.pageId]) progressByPage[msg.pageId] = {};
          progressByPage[msg.pageId].progress = msg.progress;
          progressByPage[msg.pageId].done = !!msg.done;
          updateOverallProgress();
          renderPagesList();
        }
        if (msg && msg.type === 'set-file-key') {
          setCurrentFileKey(msg.fileKey);
        }
        if (msg && msg.type === 'selection-status') {
          updateIndexButtonsState(msg.hasSelection, msg.hasFrameSelection);
          
          // Update tag system with actual Figma selection
          if (msg.selectedFrames) {
            console.log('Selection updated:', msg.selectedFrames);
            figmaSelectedFrameIds = msg.selectedFrames;
            updateSelectedFramesInfo();
            updateTagDisplay();
          }
        }
        
        if (msg && msg.type === 'frame-tags-loaded') {
          frameTags = msg.tags || {};
          console.log('Frame tags loaded:', frameTags);
          
          // Load allTags from plugin if provided, otherwise build from frameTags
          if (msg.allTags) {
            allTags = msg.allTags || [];
            console.log('AllTags loaded from plugin:', allTags);
          } else {
            // Fallback: build allTags from frameTags
            allTags = [];
            Object.values(frameTags).forEach(tags => {
              tags.forEach(tag => {
                if (!allTags.includes(tag)) {
                  allTags.push(tag);
                }
              });
            });
            console.log('Built allTags from frameTags:', allTags);
          }
          
          updateTagDisplay();
          updateTagStatistics();
          
          // Load custom tags in drawer if it's open
          const webDrawer = document.getElementById('webDrawer');
          if (webDrawer && webDrawer.style.right === '0px') {
            loadCustomTags();
          }
        }
        if (msg?.type === 'set-image-quality') {
          applyImageQuality(msg.quality);
          // Update slider and label
          const qualitySlider = document.getElementById('qualitySlider');
          if (qualitySlider) {
            const percentage = Math.round(msg.quality * 100);
            qualitySlider.value = percentage;
            updateQualityLabel(percentage);
            updateSliderFill(percentage);
          }
          return;
        }
        if (msg?.type === 'set-selected-pages') {
          selectedPages = msg.pages || [];
          hasRestoredSelection = true;
          renderPagesList();
          updateToggleSelectCheckbox();
          return;
        }
        
        if (msg?.type === 'upload-success') {
          if (window.uploadOverlay) {
            const statusDiv = window.uploadOverlay.querySelector('#uploadStatus');
            if (statusDiv) {
              statusDiv.textContent = '✅ Upload successful!';
              statusDiv.style.color = '#43a047';
            }
                         setTimeout(() => {
               if (msg.projectId.includes('-demo-')) {
                 alert(`✅ Upload completed (Demo Mode)!\n\nProject ID: ${msg.projectId}\n\n📋 Index Summary:\n• File: ${fileName}\n• Frames: ${(msg.data && msg.data.frames && msg.data.frames.length) || 0}\n• Data Size: ${msg.data ? Math.round(JSON.stringify(msg.data).length / 1024) : 0} KB\n\n💡 Note: This is a demo upload. In production, your data would be uploaded to the web system.`);
               } else {
                 alert(`✅ Upload successful!\nProject ID: ${msg.projectId}`);
               }
               document.body.removeChild(window.uploadOverlay);
               window.uploadOverlay = null;
             }, 1000);
          }
          return;
        }
        
        if (msg?.type === 'upload-error') {
          if (window.uploadOverlay) {
            const statusDiv = window.uploadOverlay.querySelector('#uploadStatus');
            if (statusDiv) {
              statusDiv.textContent = `❌ Upload failed: ${msg.message}`;
              statusDiv.style.color = '#f44336';
            }
            setTimeout(() => {
              alert(`❌ Upload failed: ${msg.message}`);
              document.body.removeChild(window.uploadOverlay);
              window.uploadOverlay = null;
            }, 2000);
          }
          return;
        }
        
        if (msg?.type === 'reset-all-data-complete') {
          // Reset all UI state
          // Clear file key
          setCurrentFileKey('');
          updateCurrentFileKeyLabel();
          
          // Reset selected pages
          selectedPages = [];
          renderPagesList();
          
          // Reset frame tags
          frameTags = {};
          allTags = [];
          updateTagDisplay();
          
          // Reset connection status
          webSystemToken = null;
          webSystemUser = null;
          updateConnectionStatus();
          
          // Reset document ID display
          const documentIdDisplay = document.getElementById('documentIdDisplay');
          if (documentIdDisplay) {
            documentIdDisplay.textContent = 'Document ID: -';
            documentIdDisplay.style.color = '#aaa';
          }
          
          // Reset image quality slider to default
          const qualitySlider = document.getElementById('qualitySlider');
          if (qualitySlider) {
            qualitySlider.value = 60;
            updateQualityLabel(60);
            updateSliderFill(60);
          }
          
          alert('✅ All plugin data has been reset!');
          return;
        }
        
        if (msg?.type === 'upload-progress') {
          if (window.uploadOverlay) {
            const statusDiv = window.uploadOverlay.querySelector('#uploadStatus');
            const progressBar = window.uploadOverlay.querySelector('#progressBar');
            const detailsDiv = window.uploadOverlay.querySelector('#uploadDetails');
            
            if (statusDiv) {
              statusDiv.textContent = `Uploading... ${msg.progress}%`;
            }
            if (progressBar) {
              progressBar.style.width = `${msg.progress}%`;
            }
            if (detailsDiv) {
              detailsDiv.textContent = `Step ${msg.step || 'unknown'}`;
            }
          }
          return;
        }
        
        if (msg?.type === 'upload-data-ready') {
          
          // Use existing Supabase upload function
          parent.postMessage({
            pluginMessage: {
              type: 'upload-index',
              indexData: msg.indexData
            }
          }, '*');
          return;
        }
        
        if (msg?.type === 'upload-result') {
          
          if (msg.success) {
            alert('Index uploaded successfully!');
            
            // Update progress
            if (window.uploadOverlay) {
              const progressBar = window.uploadOverlay.querySelector('#progressBar');
              const detailsDiv = window.uploadOverlay.querySelector('#uploadDetails');
              if (progressBar) progressBar.style.width = '100%';
              if (detailsDiv) detailsDiv.textContent = 'Upload completed!';
            }
          } else {
            console.error('Upload failed:', msg.error);
            alert('Upload failed: ' + msg.error);
          }
          return;
        }
        if (typeof origOnMessage === 'function') origOnMessage(event);
      };
      // On load, ask for selection status, file key, and pages
      parent.postMessage({ pluginMessage: { type: 'check-selection' } }, '*');
      parent.postMessage({ pluginMessage: { type: 'get-file-key' } }, '*');
      parent.postMessage({ pluginMessage: { type: 'get-pages' } }, '*');
      
      // Initialize tag system
      initializeTagSystem();

      // Add global message listener for login window
      window.addEventListener('message', function(event) {
        
        // Handle OAuth success from web system
        if (event.data.type === 'oauth_success') {
          webSystemToken = event.data.apiKey;
          webSystemUser = event.data.user;
          updateWebLoginStatus();
          alert('Successfully connected to web system!');
        }
        
        // Legacy support for old login-success format
        if (event.data.type === 'login-success') {
          webSystemToken = event.data.token;
          webSystemUser = event.data.user;
          updateWebLoginStatus();
        }
      });
      
      // Web system data will be loaded from FigDex page via plugin message
      
      // Check URL parameters for token
      function checkUrlForToken() {
        try {
          const urlParams = new URLSearchParams(window.location.search);
          const token = urlParams.get('token');
          const userStr = urlParams.get('user');
          
          if (token && userStr) {
            webSystemToken = token;
            webSystemUser = JSON.parse(decodeURIComponent(userStr));
            updateWebLoginStatus();
            return true;
          }
        } catch (e) {
        }
        return false;
      }
      
      // Check URL parameters on page load
      checkUrlForToken();
      
      // Check cookies for token
      function checkCookiesForToken() {
        try {
          const cookies = document.cookie.split(';');
          let token = null;
          let userStr = null;
          
          for (let cookie of cookies) {
            const [name, value] = cookie.trim().split('=');
            if (name === 'figma_web_token') {
              token = value;
            } else if (name === 'figma_web_user') {
              userStr = decodeURIComponent(value);
            }
          }
          
          if (token && userStr) {
            webSystemToken = token;
            webSystemUser = JSON.parse(userStr);
            updateWebLoginStatus();
            return true;
          }
        } catch (e) {
        }
        return false;
      }
      
      // Check cookies on page load
      checkCookiesForToken();
      
      // Note: localStorage and cookies are not available in data: URLs
      
      // Listen for BroadcastChannel messages
      let broadcastChannel;
      try {
        broadcastChannel = new BroadcastChannel('figma-login');
        broadcastChannel.onmessage = function(event) {
          
          if (event.data.type === 'login-success') {
            webSystemToken = event.data.token;
            webSystemUser = event.data.user;
            updateWebLoginStatus();
          }
        };
      } catch (e) {
      }

      // Load API Key from storage when page loads
      function loadApiKeyFromStorage() {
        // Load from FigDex page (handled by plugin)
        // This function is kept for compatibility but data comes from plugin
      }
      
      // Call load function when page loads
      loadApiKeyFromStorage();
      
      // show/hide overlay+drawer on isIndexing
      function showProgressDrawer() {
        document.getElementById('progressOverlay').style.display = 'block';
        document.getElementById('mainContentOverlay').style.display = 'block';
        document.getElementById('progressDrawer').style.display = 'block';
      }
      function hideProgressDrawer() {
        document.getElementById('progressOverlay').style.display = 'none';
        document.getElementById('mainContentOverlay').style.display = 'none';
        document.getElementById('progressDrawer').style.display = 'none';
      }
      
      
    </script>
  </body>
</html>

