             const minutes = Math.floor(elapsedSeconds / 60);
             const seconds = Math.floor(elapsedSeconds % 60);
             if (minutes > 0) {
               uploadTimeSpan.textContent = `• Time: ${minutes}m ${seconds}s`;
             } else {
               uploadTimeSpan.textContent = `• Time: ${seconds}s`;
             }
           }
           if (fileStatusSpan) fileStatusSpan.textContent = `• Status: ${fileStatus}`;
         }
       }
       
       // Upload timer for tracking upload duration
       let uploadStartTime = null;
       let uploadTimerInterval = null;
       
       function startUploadTimer() {
         uploadStartTime = Date.now();
         if (uploadTimerInterval) clearInterval(uploadTimerInterval);
         uploadTimerInterval = setInterval(() => {
           if (uploadStartTime && window.uploadOverlay) {
             const elapsed = (Date.now() - uploadStartTime) / 1000;
             const uploadTimeSpan = window.uploadOverlay.querySelector('#uploadTime');
             if (uploadTimeSpan) {
               const minutes = Math.floor(elapsed / 60);
               const seconds = Math.floor(elapsed % 60);
               if (minutes > 0) {
                 uploadTimeSpan.textContent = `• Time: ${minutes}m ${seconds}s`;
               } else {
                 uploadTimeSpan.textContent = `• Time: ${seconds}s`;
               }
             }
           }
         }, 1000);
       }
       
       function stopUploadTimer() {
         if (uploadTimerInterval) {
           clearInterval(uploadTimerInterval);
           uploadTimerInterval = null;
         }
         if (uploadStartTime) {
           const elapsed = (Date.now() - uploadStartTime) / 1000;
           uploadStartTime = null;
           return elapsed;
         }
         return 0;
       }
       
      
