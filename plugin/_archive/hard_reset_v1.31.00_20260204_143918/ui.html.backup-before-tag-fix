              if (msgType === 'file-data-ready') {
                resolved = true;
                cleanup();
                const fileData = event.data.pluginMessage;
                console.log('✅ File data received from plugin:', fileData);
                // Use fileName from plugin - if it's 'Untitled', keep it and let API handle it
                // The API will use fileKey as fallback if fileName is 'Untitled'
                resolve(fileData);
              }
            };
            
            console.log('👂 Registering message event listener');
            window.addEventListener('message', handleFileData);
            
            // Timeout after 10 seconds if no response
            timeoutId = setTimeout(() => {
              if (!resolved) {
                resolved = true;
                cleanup();
                const errorMsg = '❌ Timeout: Plugin did not respond\n\nThe plugin did not respond within 10 seconds. Please try:\n\n1. Reload the plugin\n2. Make sure the file is properly opened in Figma\n3. Check the browser console for errors';
